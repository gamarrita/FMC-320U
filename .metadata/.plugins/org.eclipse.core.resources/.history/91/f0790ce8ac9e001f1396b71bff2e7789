/*
 * @brief   Loop infinito flowmeet.
 * @Note    El programa princial se derarrolla en este modulo. No escribir codigo en archivos
 *          generados automaticamente por los IDEs.
 * @param   Ninguno.
 * @retval  Ninguno.
 *
 */
void FM_MAIN_Main()
{
  GPIO_InitTypeDef gpio_init = {0};
  GPIO_PinState pin_setup_1_state;

  HAL_Delay(100);

  /*Configure GPIO pin : PtPin */
  gpio_init.Pin = SETUP_1_Pin;
  gpio_init.Mode = GPIO_MODE_INPUT;
  gpio_init.Pull = GPIO_PULLUP;
  HAL_GPIO_Init(SETUP_1_GPIO_Port, &gpio_init);


  for(;;)
  {
    pin_setup_1_state = HAL_GPIO_ReadPin(SETUP_1_GPIO_Port, SETUP_1_Pin);
    if(pin_setup_1_state == GPIO_PIN_SET)
    {
      HAL_GPIO_WritePin(LED_SIGNAL_GPIO_Port, LED_SIGNAL_Pin, GPIO_PIN_RESET);
    }
    else
    {
      HAL_GPIO_WritePin(LED_SIGNAL_GPIO_Port, LED_SIGNAL_Pin, GPIO_PIN_SET);
    }

      HAL_GPIO_WritePin(LED_ACTIVE_GPIO_Port, LED_ACTIVE_Pin, GPIO_PIN_RESET);
      HAL_PWREx_EnterSTOP2Mode(PWR_STOPENTRY_WFI);
      HAL_GPIO_WritePin(LED_ACTIVE_GPIO_Port, LED_ACTIVE_Pin, GPIO_PIN_SET);
  }
}

